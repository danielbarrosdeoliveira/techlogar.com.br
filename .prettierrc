{
	"arrowParens": "always",
	"bracketSameLine": false,
	"printWidth": 100,
	"semi": true,
	"endOfLine": "lf",
	"bracketSpacing": true,
	"singleQuote": true,
	"insertPragma": false,
	"singleAttributePerLine": true,
	"useTabs": true,
	"trailingComma": "es5",
	"quoteProps": "as-needed",
	"plugins": ["prettier-plugin-tailwindcss"],
	"vueIndentScriptAndStyle": false
}
